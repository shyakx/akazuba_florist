# Production Environment Variables for Akazuba Florist

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://akazubaflorist.com
NEXT_PUBLIC_APP_NAME=Akazuba Florist
NEXT_PUBLIC_APP_DESCRIPTION=Premium flowers and perfumes in Rwanda

# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://akazuba_user:your_secure_password@akazuba-db.cluster-xyz.us-east-1.rds.amazonaws.com:5432/akazuba_production
DB_HOST=akazuba-db.cluster-xyz.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=akazuba_production
DB_USER=akazuba_user
DB_PASSWORD=your_secure_password

# JWT Authentication
JWT_SECRET=your_super_secure_jwt_secret_key_for_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_for_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend API
BACKEND_URL=https://api.akazuba.com
NEXT_PUBLIC_API_URL=https://api.akazuba.com

# File Upload (AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=akazuba-production-assets
AWS_S3_BUCKET_URL=https://akazuba-production-assets.s3.us-east-1.amazonaws.com

# Email Service (AWS SES)
EMAIL_FROM=noreply@akazuba.com
EMAIL_SERVICE=ses
AWS_SES_REGION=us-east-1

# Payment Integration (Local Payment with Proof Upload)
PAYMENT_METHOD=local_upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
FACEBOOK_PIXEL_ID=your_facebook_pixel_id

# Security
CORS_ORIGIN=https://akazuba.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Performance
CACHE_TTL=3600
REDIS_URL=redis://akazuba-redis.xxxxx.cache.amazonaws.com:6379

# Monitoring
SENTRY_DSN=your_sentry_dsn_for_error_monitoring
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
